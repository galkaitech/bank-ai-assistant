# ---------------------------------------------------------------------------
# BankMind — Environment Variable Configuration
# ---------------------------------------------------------------------------
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# IMPORTANT:
# - Never commit .env to source control (it is in .gitignore)
# - For production, use a secrets manager (Azure Key Vault, HashiCorp Vault)
#   rather than a .env file
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
APP_MODE=development              # development | demo | production
LOG_LEVEL=INFO                    # DEBUG | INFO | WARNING | ERROR

# ---------------------------------------------------------------------------
# OpenAI (default LLM provider)
# ---------------------------------------------------------------------------
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Model selection — override defaults if needed
LLM_MODEL=gpt-4o
LLM_MODEL_DOC_QA=gpt-4o-mini
LLM_MODEL_REPORTS=gpt-4o
LLM_MODEL_COMPLIANCE=gpt-4o

# ---------------------------------------------------------------------------
# Azure OpenAI (alternative to OpenAI — for data residency requirements)
# Leave blank to use OpenAI directly
# ---------------------------------------------------------------------------
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-02-01

# ---------------------------------------------------------------------------
# Embedding Model
# ---------------------------------------------------------------------------
EMBEDDING_MODEL=text-embedding-3-small

# ---------------------------------------------------------------------------
# Vector Store
# ---------------------------------------------------------------------------
VECTOR_STORE_TYPE=chroma          # chroma | pinecone | pgvector

# ChromaDB settings (used when VECTOR_STORE_TYPE=chroma)
CHROMA_PERSIST_DIR=./data/chroma_db
CHROMA_COLLECTION_NAME=bankmind_docs

# Pinecone settings (used when VECTOR_STORE_TYPE=pinecone)
PINECONE_API_KEY=
PINECONE_INDEX_NAME=bankmind-docs
PINECONE_ENVIRONMENT=gcp-starter

# ---------------------------------------------------------------------------
# Document Processing
# ---------------------------------------------------------------------------
DOC_SOURCE_DIR=./data/sample_docs
CHUNK_SIZE=800
CHUNK_OVERLAP=100
RETRIEVAL_TOP_K=4

# ---------------------------------------------------------------------------
# API Server
# ---------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=2

# ---------------------------------------------------------------------------
# Security & Compliance
# ---------------------------------------------------------------------------
ENABLE_PII_FILTER=true
ENABLE_AUDIT_LOGGING=true
AUDIT_LOG_PATH=./logs/audit.jsonl
MAX_DOCUMENT_SIZE_MB=20.0
